generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Hotel {
  id          Int          @id @default(autoincrement())
  name        String
  address     String?
  description String?
  policies    String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  images      HotelImage[]
}

model HotelImage {
  id        Int      @id @default(autoincrement())
  hotelId   Int      @map("hotel_id")
  url       String
  alt       String?
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
}

model RoomType {
  id                Int                 @id @default(autoincrement())
  name              String
  capacity          Int
  description       String?             @db.Text
  isActive          Boolean             @default(true) @map("is_active")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  basePrice         Decimal             @db.Decimal(10, 2)
  PromotionRoomType PromotionRoomType[]
  rooms             Room[]
  amenities         RoomTypeAmenity[]
  images            RoomTypeImage[]
  promotions        Promotion[]         @relation("PromotionRoomTypes")

  @@index([name])
}

model RoomTypeImage {
  id         Int      @id @default(autoincrement())
  roomTypeId Int      @map("room_type_id")
  url        String
  alt        String?
  isPrimary  Boolean  @default(false) @map("is_primary")
  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@index([roomTypeId])
}

model Amenity {
  id                Int               @id @default(autoincrement())
  code              String            @unique
  label             String
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  roomTypeAmenities RoomTypeAmenity[]
}

model RoomTypeAmenity {
  id         Int      @id @default(autoincrement())
  roomTypeId Int      @map("room_type_id")
  amenityId  Int      @map("amenity_id")
  amenity    Amenity  @relation(fields: [amenityId], references: [id])
  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, amenityId])
  @@index([roomTypeId])
  @@index([amenityId])
}

model Room {
  id                Int                @id @default(autoincrement())
  name              String?
  roomTypeId        Int                @map("room_type_id")
  status            Room_status        @default(VACANT_CLEAN)
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  bookings          Booking[]
  roomType          RoomType           @relation(fields: [roomTypeId], references: [id])
  housekeepingTasks HousekeepingTask[]

  @@index([roomTypeId])
  @@index([status])
}

model Promotion {
  id                Int                 @id @default(autoincrement())
  name              String
  code              String?             @unique
  autoApply         Boolean             @default(false) @map("auto_apply")
  type              PromoType
  value             Decimal             @db.Decimal(10, 2)
  startAt           DateTime            @map("start_at")
  endAt             DateTime            @map("end_at")
  isActive          Boolean             @default(true) @map("is_active")
  priority          Int                 @default(100)
  isStackable       Boolean             @default(false) @map("is_stackable")
  quotaUsed         Int                 @default(0) @map("quota_used")
  quotaTotal        Int                 @default(100) @map("quota_total")
  scope             PromoScope
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  maxDiscountAmount Decimal?            @db.Decimal(10, 2)
  minTotal          Decimal?            @db.Decimal(10, 2)
  description       String?             @db.Text
  eligibleFor       CustomerType        @default(ALL) @map("eligible_for")
  PromotionRoomType PromotionRoomType[]
  roomTypes         RoomType[]          @relation("PromotionRoomTypes")
  InvoiceItem       InvoiceItem[]

  @@index([scope])
  @@index([startAt, endAt])
}

model PromotionRoomType {
  promotionId Int
  roomTypeId  Int
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  roomType    RoomType  @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@id([promotionId, roomTypeId])
  @@index([promotionId])
  @@index([roomTypeId])
}

model User {
  id           Int                  @id @default(autoincrement())
  fullName     String               @map("full_name")
  email        String?              @unique
  phone        String?              @unique
  passwordHash String               @map("password_hash")
  type         UserType             @default(CUSTOMER)
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  isActive     Boolean              @default(true) @map("is_active")
  customer     Customer?
  resetTokens  PasswordResetToken[]
  staff        Staff?
}

model Staff {
  id                Int                    @id @default(autoincrement())
  userId            Int                    @unique @map("user_id")
  position          StaffPosition
  isAdmin           Boolean                @default(false) @map("is_admin")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  bookings          Booking[]
  CancelReason      CancelReason[]
  Review            Review[]
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  shiftAssignments  StaffShiftAssignment[]
  housekeepingTasks HousekeepingTask[]
}

model Customer {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  bookings  Booking[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Booking {
  id          Int       @id @default(autoincrement())
  customerId  Int?      @map("customer_id")
  staffId     Int?      @map("staff_id")
  roomId      Int       @map("room_id")
  checkIn     DateTime  @map("check_in")
  checkOut    DateTime  @map("check_out")
  fullName    String    @map("full_name")
  phone       String
  email       String?
  guestType   GuestType @default(OTHER) @map("guest_type")
  arrivalTime String?   @map("arrival_time")

  status       BookingStatus @default(PENDING)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  customer     Customer?     @relation(fields: [customerId], references: [id])
  room         Room          @relation(fields: [roomId], references: [id])
  staff        Staff?        @relation(fields: [staffId], references: [id])
  cancelReason CancelReason?
  review       Review?
  invoice      Invoice?
  housekeepingTasks HousekeepingTask[] 

  @@index([roomId, checkIn, checkOut])
  @@index([customerId])
  @@index([staffId])
  @@index([status, checkIn])
}

model Review {
  id            Int          @id @default(autoincrement())
  bookingId     Int          @unique @map("booking_id")
  overall       Int
  amenities     Int?
  cleanliness   Int?
  comfort       Int?
  locationScore Int?         @map("location_score")
  valueForMoney Int?         @map("value_for_money")
  hygiene       Int?
  comment       String?      @db.Text
  isActive      Boolean      @default(true) @map("is_active")
  status        ReviewStatus @default(PUBLISHED)
  staffId       Int?         @map("staff_id")
  staffReply    String?      @map("staff_reply") @db.Text
  staffReplyAt  DateTime?    @map("staff_reply_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  booking       Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  staff         Staff?       @relation(fields: [staffId], references: [id])

  @@index([status])
  @@index([staffId])
}

model CancelReason {
  id        Int      @id @default(autoincrement())
  bookingId Int      @unique @map("booking_id")
  userId    Int?     @map("user_id")
  staffId   Int?     @map("staff_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  staff     Staff?   @relation(fields: [staffId], references: [id])

  @@index([userId])
  @@index([staffId])
}

model Payment {
  id        Int @id @default(autoincrement())
  invoiceId Int @map("invoice_id")

  type PaymentType @default(ROOM)

  amount Decimal       @db.Decimal(10, 2)
  method PaymentMethod
  paidAt DateTime?     @map("paid_at")

  status PaymentStatus @default(UNPAID)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([status, createdAt])
}

model Invoice {
  id        Int           @id @default(autoincrement())
  bookingId Int           @unique @map("booking_id")
  status    InvoiceStatus @default(DRAFT)

  subtotal   Decimal @default(0.00) @db.Decimal(10, 2)
  discount   Decimal @default(0.00) @db.Decimal(10, 2)
  tax        Decimal @default(0.00) @db.Decimal(10, 2)
  paidAmount Decimal @default(0.00) @map("paid_amount") @db.Decimal(10, 2)

  note String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  booking  Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  items    InvoiceItem[]
  payments Payment[]

  @@index([bookingId])
}

model InvoiceItem {
  id          Int             @id @default(autoincrement())
  invoiceId   Int             @map("invoice_id")
  type        InvoiceItemType
  description String?
  quantity    Int             @default(1)

  unitPrice  Decimal @map("unit_price") @db.Decimal(10, 2)
  totalPrice Decimal @map("total_price") @db.Decimal(10, 2)

  serviceId   Int? @map("service_id")
  promotionId Int? @map("promotion_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoice   Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service   Service?   @relation(fields: [serviceId], references: [id])
  promotion Promotion? @relation(fields: [promotionId], references: [id])

  @@index([invoiceId])
  @@index([serviceId])
}

model Service {
  id          Int     @id @default(autoincrement())
  name        String
  description String? @db.Text
  price       Decimal @db.Decimal(10, 2)

  type ServiceType @default(SERVICE)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoiceItems InvoiceItem[]

  @@index([name])
  @@index([type])
}

model Shift {
  id          Int                    @id @default(autoincrement())
  code        String                 @unique
  name        String
  startTime   DateTime               @map("start_time") @db.Time(0)
  endTime     DateTime               @map("end_time") @db.Time(0)
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")
  assignments StaffShiftAssignment[]
}

model StaffShiftAssignment {
  id        Int           @id @default(autoincrement())
  staffId   Int           @map("staff_id")
  shiftId   Int           @map("shift_id")
  workDate  DateTime      @map("work_date") @db.Date
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  position  StaffPosition @map("position_at_that_time")
  shift     Shift         @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  staff     Staff         @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, shiftId, workDate])
  @@index([workDate])
  @@index([staffId])
  @@index([shiftId])
}

model HousekeepingTask {
  id        Int                  @id @default(autoincrement())
  roomId    Int                  @map("room_id")
  bookingId Int?                 @map("booking_id")   
  staffId   Int?                 @map("staff_id")
  workDate  DateTime             @map("work_date")
  type      HousekeepingTaskType @default(CLEANING)
  status    TaskStatus           @default(PENDING)
  note      String?              @db.Text
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")

  room    Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id])
  staff   Staff?   @relation(fields: [staffId], references: [id])

  @@unique([roomId, workDate, type])
  @@index([roomId])
  @@index([bookingId]) 
  @@index([staffId])
  @@index([workDate])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  CHECKED_IN
  CHECKED_OUT
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MOMO
  ZALOPAY
  VNPAY
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
  FAILED
}

enum InvoiceStatus {
  DRAFT
  ACTIVE
  PAID
  CANCELLED
}

enum InvoiceItemType {
  ROOM
  SERVICE
  EXTRA_FEE
}

enum PromoType {
  PERCENT
  FIXED
}

enum PromoScope {
  GLOBAL
  ROOM_TYPE
  MIN_TOTAL
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
}

enum GuestType {
  SELF
  OTHER
}

enum StaffPosition {
  MANAGER
  RECEPTION
  HOUSEKEEPING
}

enum UserType {
  STAFF
  CUSTOMER
}

enum CustomerType {
  REGISTERED_MEMBER
  GUEST
  ALL
}

enum Room_status {
  VACANT_CLEAN
  VACANT_DIRTY
  OCCUPIED_CLEAN
  OCCUPIED_DIRTY
  OUT_OF_SERVICE
}

enum HousekeepingTaskType {
  INSPECTION
  CLEANING
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum ServiceType {
  SERVICE
  EXTRA_FEE
}

enum PaymentType {
  DEPOSIT
  ROOM
  SERVICE
}
