generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Hotel {
  id          Int      @id @default(autoincrement())
  name        String
  address     String?
  description String?
  policies    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  images HotelImage[]
}

model HotelImage {
  id        Int      @id @default(autoincrement())
  hotelId   Int      @map("hotel_id")
  url       String
  alt       String?
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([hotelId])
}

model RoomType {
  id          Int      @id @default(autoincrement())
  name        String
  basePrice   Decimal  @db.Decimal(10, 2)
  capacity    Int
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  promotions Promotion[] @relation("PromotionRoomTypes")

  images            RoomTypeImage[]
  amenities         RoomTypeAmenity[]
  rooms             Room[]
  PromotionRoomType PromotionRoomType[]

  @@index([name])
}

model RoomTypeImage {
  id         Int     @id @default(autoincrement())
  roomTypeId Int     @map("room_type_id")
  url        String
  alt        String?
  isPrimary  Boolean @default(false) @map("is_primary")

  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([roomTypeId])
}

model Amenity {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  label     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  roomTypeAmenities RoomTypeAmenity[]
}

model RoomTypeAmenity {
  id         Int @id @default(autoincrement())
  roomTypeId Int @map("room_type_id")
  amenityId  Int @map("amenity_id")

  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  amenity  Amenity  @relation(fields: [amenityId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([roomTypeId, amenityId])
  @@index([roomTypeId])
  @@index([amenityId])
}

model Room {
  id         Int        @id @default(autoincrement())
  name       String?
  roomTypeId Int        @map("room_type_id")
  status     RoomStatus @default(AVAILABLE)
  isActive   Boolean    @default(true) @map("is_active")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  roomType RoomType  @relation(fields: [roomTypeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  bookings Booking[]

  @@index([roomTypeId])
  @@index([status])
}

model Promotion {
  id                Int        @id @default(autoincrement())
  name              String
  code              String?
  description       String?    @db.Text
  autoApply         Boolean    @default(false) @map("auto_apply")
  type              PromoType
  value             Decimal    @db.Decimal(10, 2)
  startAt           DateTime   @map("start_at")
  endAt             DateTime   @map("end_at")
  isActive          Boolean    @default(true) @map("is_active")
  eligibleFor         CustomerType @default(ALL) @map("eligible_for")
  priority          Int        @default(100)
  isStackable       Boolean    @default(false) @map("is_stackable")
  quotaUsed         Int        @default(0) @map("quota_used")
  quotaTotal        Int        @default(100) @map("quota_total")
  scope             PromoScope
  minTotal          Decimal?   @db.Decimal(10, 2)
  maxDiscountAmount Decimal?   @db.Decimal(10, 2)
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  roomTypes RoomType[] @relation("PromotionRoomTypes")

  bookings          Booking[]
  PromotionRoomType PromotionRoomType[]

  @@unique([code])
  @@index([scope])
  @@index([startAt, endAt])
}

model PromotionRoomType {
  promotionId Int
  roomTypeId  Int

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  roomType  RoomType  @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@id([promotionId, roomTypeId])
  @@index([promotionId])
  @@index([roomTypeId])
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String   @map("full_name")
  email        String?  @unique
  phone        String?  @unique
  passwordHash String   @map("password_hash")
  type         UserType @default(CUSTOMER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  staff       Staff?
  customer    Customer?
  resetTokens PasswordResetToken[]
}

model Staff {
  id        Int            @id @default(autoincrement())
  userId    Int            @unique @map("user_id")
  position  StaffPosition
  isAdmin   Boolean        @default(false) @map("is_admin")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bookings     Booking[]
  Review       Review[]
  CancelReason CancelReason[]
}

model Customer {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique @map("user_id")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bookings  Booking[]
}

model PasswordResetToken {
  id Int @id @default(autoincrement())

  userId Int @map("user_id")

  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Booking {
  id         Int      @id @default(autoincrement())
  customerId Int?     @map("customer_id")
  staffId    Int?     @map("staff_id")
  roomId     Int      @map("room_id")
  checkIn    DateTime @map("check_in")
  checkOut   DateTime @map("check_out")

  fullName    String    @map("full_name")
  phone       String
  email       String?
  guestType   GuestType @default(OTHER) @map("guest_type")
  arrivalTime String?   @map("arrival_time")

  promotionId    Int?          @map("promotion_id")
  baseAmount     Decimal       @map("base_amount") @db.Decimal(10, 2)
  discountAmount Decimal       @default(0) @map("discount_amount") @db.Decimal(10, 2)
  paymentStatus  PaymentStatus @default(UNPAID) @map("payment_status")
  totalPaid      Decimal       @default(0) @map("total_paid") @db.Decimal(10, 2)
  status         BookingStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer  Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  staff     Staff?     @relation(fields: [staffId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  room      Room       @relation(fields: [roomId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  promotion Promotion? @relation(fields: [promotionId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  review       Review?
  cancelReason CancelReason?
  payments     Payment[]

  @@index([roomId, checkIn, checkOut])
  @@index([customerId])
  @@index([staffId])
  @@index([promotionId])
  @@index([status, checkIn])
}

model Review {
  id            Int     @id @default(autoincrement())
  bookingId     Int     @unique @map("booking_id")
  overall       Int
  amenities     Int?
  cleanliness   Int?
  comfort       Int?
  locationScore Int?    @map("location_score")
  valueForMoney Int?    @map("value_for_money")
  hygiene       Int?
  comment       String? @db.Text

  isActive Boolean      @default(true) @map("is_active")
  status   ReviewStatus @default(PUBLISHED)

  staffId      Int?      @map("staff_id")
  staffReply   String?   @map("staff_reply") @db.Text
  staffReplyAt DateTime? @map("staff_reply_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  staff   Staff?  @relation(fields: [staffId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([status])
  @@index([staffId])
}

model CancelReason {
  id        Int      @id @default(autoincrement())
  bookingId Int      @unique @map("booking_id")
  userId    Int?     @map("user_id")
  staffId   Int?     @map("staff_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  staff   Staff?  @relation(fields: [staffId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([userId])
  @@index([staffId])
}

model Payment {
  id        Int           @id @default(autoincrement())
  bookingId Int           @map("booking_id")
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod
  paidAt    DateTime?     @map("paid_at")
  status    PaymentStatus @default(UNPAID)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([bookingId])
  @@index([status, createdAt])
}

enum RoomStatus {
  AVAILABLE
  BOOKED
  MAINTENANCE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  CHECKED_IN
  CHECKED_OUT
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MOMO
  ZALOPAY
  VNPAY
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
  FAILED
}

enum PromoType {
  PERCENT
  FIXED
}

enum PromoScope {
  GLOBAL
  ROOM_TYPE
  MIN_TOTAL
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
}

enum GuestType {
  SELF
  OTHER
}

enum StaffPosition {
  MANAGER
  RECEPTION
  HOUSEKEEPING
}

enum UserType {
  STAFF
  CUSTOMER
}

enum CustomerType {
  REGISTERED_MEMBER
  GUEST
  ALL
}
